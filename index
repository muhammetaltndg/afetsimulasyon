<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Extreme Event Türkiye</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      background: #0f172a;
      color: #e2e8f0;
      overflow-x: hidden;
    }

    .glass {
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .card-hover:hover {
      transform: translateY(-4px);
      transition: 0.25s;
    }

    .pulse-alert {
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(239,68,68,.7); }
      70% { box-shadow: 0 0 0 16px rgba(239,68,68,0); }
      100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); }
    }
  </style>
</head>
<body class="min-h-screen">

<div id="app" class="p-4 md:p-8 max-w-7xl mx-auto"></div>

<script>

// =========================================
// OYUN VERİLERİ
// =========================================

const senaryolar = {
  sel: {
    ad: 'Sel Felaketi',
    renk: 'from-cyan-600 to-blue-900',
    aciklama: 'Şiddetli yağış sonrası şehir su altında kalıyor.',
    olaylar: [
      'Baraj taşmak üzere!',
      'Kıyı mahallesinde elektrik kesildi!',
      'Tahliye yolları kapanıyor!'
    ]
  },
  deprem: {
    ad: 'Deprem',
    renk: 'from-orange-600 to-red-900',
    aciklama: 'Büyük bir deprem şehir altyapısını çökertiyor.',
    olaylar: [
      'Doğalgaz hattında patlama!',
      'Köprü çöktü!',
      'Artçı sarsıntılar devam ediyor!'
    ]
  },
  kasirga: {
    ad: 'Kasırga',
    renk: 'from-purple-700 to-slate-900',
    aciklama: 'Yıkıcı rüzgarlar ve altyapı hasarı büyüyor.',
    olaylar: [
      'Elektrik şebekesi çöktü!',
      'Ağaçlar yolları kapattı!',
      'İletişim kuleleri hasar gördü!'
    ]
  }
};

const sektorler = [
  {
    id: 'hane',
    ad: 'Hanehalkı',
    icon: 'home',
    renk: 'bg-emerald-600'
  },
  {
    id: 'toplum',
    ad: 'Topluluk Grupları',
    icon: 'users',
    renk: 'bg-cyan-600'
  },
  {
    id: 'isletme',
    ad: 'İşletmeler',
    icon: 'building-2',
    renk: 'bg-amber-600'
  },
  {
    id: 'ilk',
    ad: 'İlk Müdahale Ekipleri',
    icon: 'shield-alert',
    renk: 'bg-red-600'
  },
  {
    id: 'yerel',
    ad: 'Yerel ve Eyalet Yönetimi',
    icon: 'landmark',
    renk: 'bg-indigo-600'
  },
  {
    id: 'federal',
    ad: 'Federal Yönetim',
    icon: 'badge-alert',
    renk: 'bg-purple-700'
  }
];

// PDF kaynaklarından uyarlanan örnek kaynak havuzu
const kaynaklar = [
  {
    ad: 'Jeneratör ve Yakıt',
    sektor: 'isletme',
    maliyet: 4,
    etki: 8,
    ikon: 'battery-charging',
    aciklama: 'Elektrik kesintilerinde kritik enerji sağlar.'
  },
  {
    ad: 'Kum Torbaları',
    sektor: 'ilk',
    maliyet: 3,
    etki: 7,
    ikon: 'package',
    aciklama: 'Sel baskınlarına karşı geçici koruma sağlar.'
  },
  {
    ad: 'Acil Durum Tahliye Planı',
    sektor: 'yerel',
    maliyet: 5,
    etki: 10,
    ikon: 'map',
    aciklama: 'Vatandaşların güvenli tahliyesini hızlandırır.'
  },
  {
    ad: 'Arama Kurtarma Köpekleri',
    sektor: 'ilk',
    maliyet: 6,
    etki: 10,
    ikon: 'search',
    aciklama: 'Enkaz altında kalanların bulunmasını sağlar.'
  },
  {
    ad: 'Su Arıtma Sistemi',
    sektor: 'hane',
    maliyet: 4,
    etki: 8,
    ikon: 'droplets',
    aciklama: 'Temiz içme suyu sağlar.'
  },
  {
    ad: 'Mobil İletişim Cihazları',
    sektor: 'isletme',
    maliyet: 2,
    etki: 5,
    ikon: 'smartphone',
    aciklama: 'Afet sırasında iletişimi sürdürür.'
  },
  {
    ad: 'Toplumsal Gönüllüler',
    sektor: 'toplum',
    maliyet: 3,
    etki: 7,
    ikon: 'users',
    aciklama: 'Yerel koordinasyonu güçlendirir.'
  },
  {
    ad: 'Şehir Genel Uyarı Sistemi',
    sektor: 'yerel',
    maliyet: 5,
    etki: 9,
    ikon: 'siren',
    aciklama: 'Erken uyarı ve bilgilendirme sağlar.'
  }
];

const challengeKartlari = [
  {
    id: 1,
    baslik: 'Su Baskını Tahliyesi',
    gerekli: ['Kum Torbaları', 'Acil Durum Tahliye Planı'],
    puan: 20
  },
  {
    id: 2,
    baslik: 'Elektrik Krizi',
    gerekli: ['Jeneratör ve Yakıt'],
    puan: 15
  },
  {
    id: 3,
    baslik: 'Enkaz Kurtarma',
    gerekli: ['Arama Kurtarma Köpekleri'],
    puan: 25
  },
  {
    id: 4,
    baslik: 'Temiz Su Dağıtımı',
    gerekli: ['Su Arıtma Sistemi'],
    puan: 15
  }
];

// =========================================
// OYUN STATE
// =========================================

const state = {
  ekran: 'giris',
  senaryo: null,
  sektor: null,
  butce: 15,
  secilenKaynaklar: [],
  skor: 0,
  loglar: [],
  haberler: []
};

const app = document.getElementById('app');

// =========================================
// RENDER
// =========================================

function render() {
  switch(state.ekran) {
    case 'giris': renderGiris(); break;
    case 'sektor': renderSektor(); break;
    case 'prepare': renderPrepare(); break;
    case 'afet': renderAfet(); break;
    case 'respond': renderRespond(); break;
    case 'sonuc': renderSonuc(); break;
  }

  lucide.createIcons();
}

// =========================================
// GİRİŞ
// =========================================

function renderGiris() {
  app.innerHTML = `
    <div class="text-center py-12">
      <h1 class="text-5xl font-black mb-4">EXTREME EVENT TÜRKİYE</h1>
      <p class="text-slate-300 text-xl mb-12">YZ destekli afet dayanıklılığı simülasyonu</p>

      <div class="grid md:grid-cols-3 gap-6">
        ${Object.entries(senaryolar).map(([key,s]) => `
          <button onclick="secSenaryo('${key}')"
            class="glass rounded-3xl p-8 card-hover bg-gradient-to-br ${s.renk}">
            <h2 class="text-3xl font-bold mb-4">${s.ad}</h2>
            <p>${s.aciklama}</p>
          </button>
        `).join('')}
      </div>
    </div>
  `;
}

function secSenaryo(id) {
  state.senaryo = senaryolar[id];
  state.ekran = 'sektor';
  render();
}

// =========================================
// SEKTÖR
// =========================================

function renderSektor() {
  app.innerHTML = `
    <div>
      <h2 class="text-4xl font-bold mb-8">Sektörünü Seç</h2>

      <div class="grid md:grid-cols-3 gap-6">
        ${sektorler.map(s => `
          <button onclick="secSektor('${s.id}')"
            class="glass rounded-2xl p-6 card-hover">
            <div class="${s.renk} w-16 h-16 rounded-2xl flex items-center justify-center mb-4 mx-auto">
              <i data-lucide="${s.icon}" class="w-8 h-8"></i>
            </div>
            <h3 class="text-2xl font-bold">${s.ad}</h3>
          </button>
        `).join('')}
      </div>
    </div>
  `;
}

function secSektor(id) {
  state.sektor = sektorler.find(s => s.id === id);
  state.ekran = 'prepare';
  render();
}

// =========================================
// PREPARE PHASE
// =========================================

function renderPrepare() {

  const filtreli = kaynaklar.filter(k =>
    k.sektor === state.sektor.id
  );

  app.innerHTML = `
    <div>
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-4xl font-black">Hazırlık Aşaması</h2>
          <p class="text-slate-400">Kaynaklarını stratejik biçimde seç.</p>
        </div>

        <div class="glass px-6 py-4 rounded-2xl">
          <div class="text-sm text-slate-400">Kalan Bütçe</div>
          <div class="text-4xl font-black">${state.butce}</div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        ${filtreli.map(k => `
          <div class="glass rounded-2xl p-6">
            <div class="flex justify-between mb-4">
              <i data-lucide="${k.ikon}" class="w-10 h-10"></i>
              <div class="text-right">
                <div class="text-yellow-400 font-bold">${k.maliyet} Bütçe</div>
                <div class="text-green-400">+${k.etki} Direnç</div>
              </div>
            </div>

            <h3 class="text-xl font-bold mb-2">${k.ad}</h3>
            <p class="text-slate-400 mb-4">${k.aciklama}</p>

            <button onclick="kaynakSec('${k.ad}')"
              class="w-full bg-emerald-600 hover:bg-emerald-500 py-3 rounded-xl font-bold">
              Kaynağı Al
            </button>
          </div>
        `).join('')}
      </div>

      <button onclick="baslatAfet()"
        class="mt-10 w-full bg-red-700 hover:bg-red-600 py-5 rounded-2xl text-2xl font-black pulse-alert">
        Afeti Başlat
      </button>
    </div>
  `;
}

function kaynakSec(ad) {
  const k = kaynaklar.find(x => x.ad === ad);

  if(state.butce >= k.maliyet) {
    state.butce -= k.maliyet;
    state.skor += k.etki;
    state.secilenKaynaklar.push(k);
    render();
  }
}

// =========================================
// AFET GEÇİŞİ
// =========================================

function baslatAfet() {
  state.ekran = 'afet';
  render();

  setTimeout(() => {
    state.ekran = 'respond';
    render();
    breakingNews();
  }, 3500);
}

function renderAfet() {
  app.innerHTML = `
    <div class="min-h-[70vh] flex items-center justify-center text-center">
      <div>
        <div class="text-red-500 text-7xl font-black mb-6 animate-pulse">AFET BAŞLADI</div>
        <div class="text-3xl mb-4">${state.senaryo.ad}</div>
        <div class="text-slate-400">${rastgele(state.senaryo.olaylar)}</div>
      </div>
    </div>
  `;
}

// =========================================
// RESPOND PHASE
// =========================================

function renderRespond() {
  app.innerHTML = `
    <div>
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-4xl font-black">Müdahale Aşaması</h2>
          <p class="text-slate-400">Krizleri çöz ve toplumu ayakta tut.</p>
        </div>

        <button onclick="breakingNews()"
          class="bg-red-700 hover:bg-red-600 px-6 py-3 rounded-xl font-bold">
          Beklenmedik Haber
        </button>
      </div>

      <div id="haberKutusu" class="mb-6"></div>

      <div class="grid lg:grid-cols-2 gap-6">

        <div class="glass rounded-2xl p-6">
          <h3 class="text-2xl font-bold mb-4">Görev Kartları</h3>

          ${challengeKartlari.map(c => `
            <div class="border border-slate-700 rounded-xl p-4 mb-4">
              <div class="flex justify-between mb-2">
                <h4 class="font-bold text-xl">${c.baslik}</h4>
                <div class="text-green-400">+${c.puan}</div>
              </div>

              <div class="text-slate-400 mb-4">
                Gerekli Kaynaklar:
                ${c.gerekli.join(', ')}
              </div>

              <button onclick="gorevCoz(${c.id})"
                class="bg-cyan-600 hover:bg-cyan-500 px-4 py-2 rounded-lg">
                Görevi Çöz
              </button>
            </div>
          `).join('')}
        </div>

        <div class="glass rounded-2xl p-6">
          <h3 class="text-2xl font-bold mb-4">Envanter</h3>

          <div class="space-y-3">
            ${state.secilenKaynaklar.map(k => `
              <div class="flex items-center gap-3 bg-slate-800 rounded-xl p-3">
                <i data-lucide="${k.ikon}" class="w-5 h-5"></i>
                <span>${k.ad}</span>
              </div>
            `).join('')}
          </div>

          <button onclick="oyunuBitir()"
            class="mt-8 w-full bg-emerald-700 hover:bg-emerald-600 py-4 rounded-xl text-xl font-bold">
            Simülasyonu Bitir
          </button>
        </div>

      </div>
    </div>
  `;
}

function gorevCoz(id) {
  const gorev = challengeKartlari.find(g => g.id === id);

  const envanter = state.secilenKaynaklar.map(k => k.ad);

  const basarili = gorev.gerekli.every(g => envanter.includes(g));

  if(basarili) {
    state.skor += gorev.puan;
    alert('Görev başarıyla çözüldü!');
  } else {
    state.skor -= 5;
    alert('Yetersiz kaynak!');
  }

  render();
}

// =========================================
// YZ HABER SİSTEMİ
// =========================================

function breakingNews() {

  const haberler = [
    'X mahallesi tamamen su altında kaldı!',
    'Hastanelerde jeneratör ihtiyacı oluştu!',
    'Ana köprü çöktü, ulaşım kesildi!',
    'Sosyal medyada yanlış bilgi yayılıyor!',
    'Tahliye merkezlerinde kapasite doldu!',
    'Yeni artçı deprem riski bildirildi!'
  ];

  const haber = rastgele(haberler);

  document.getElementById('haberKutusu').innerHTML = `
    <div class="bg-red-950 border border-red-700 rounded-2xl p-6 pulse-alert">
      <div class="text-red-400 font-black text-lg mb-2">SON DAKİKA</div>
      <div class="text-2xl font-bold">${haber}</div>
    </div>
  `;

  state.loglar.push(haber);
}

// =========================================
// SONUÇ
// =========================================

function oyunuBitir() {
  state.ekran = 'sonuc';
  render();
}

function renderSonuc() {

  let derece = 'Kırılgan';

  if(state.skor > 40) derece = 'Dayanıklı';
  else if(state.skor > 25) derece = 'Gelişmekte';

  app.innerHTML = `
    <div class="max-w-4xl mx-auto text-center py-12">
      <h2 class="text-5xl font-black mb-6">Simülasyon Tamamlandı</h2>

      <div class="glass rounded-3xl p-10">

        <div class="text-7xl font-black text-emerald-400 mb-4">
          ${state.skor}
        </div>

        <div class="text-3xl mb-8">
          Toplumsal Dirençlilik Seviyesi: ${derece}
        </div>

        <div class="text-left space-y-4">
          <div>
            ✔ Güçlü kaynak koordinasyonu sağlandı.
          </div>

          <div>
            ✔ ${state.secilenKaynaklar.length} stratejik kaynak kullanıldı.
          </div>

          <div>
            ✔ ${state.loglar.length} beklenmedik kriz yönetildi.
          </div>
        </div>

        <button onclick="yenidenBaslat()"
          class="mt-10 bg-cyan-600 hover:bg-cyan-500 px-8 py-4 rounded-2xl text-xl font-bold">
          Yeniden Oyna
        </button>

      </div>
    </div>
  `;
}

function yenidenBaslat() {
  location.reload();
}

function rastgele(arr) {
  return arr[Math.floor(Math.random()*arr.length)];
}

render();

</script>
</body>
</html>
